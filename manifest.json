{
    "manifest_version": 3,
    "name": "FreqWave EQ",
    "version": "1.0.0",
    "description": "8-band Web Audio equalizer for browser tabs.",

    "permissions": ["activeTab", "tabCapture", "offscreen", "storage"],

    "action": {
        "default_popup": "src/popup/popup.html",
        "default_title": "FreqWave EQ",
        "default_icon": {
            "16": "favicon.svg",
            "32": "favicon.svg",
            "48": "favicon.svg",
            "128": "favicon.svg"
        }
    },

    "background": {
        "service_worker": "src/background/service-worker.ts",
        "type": "module"
    },

    "icons": {
        "16": "favicon.svg",
        "32": "favicon.svg",
        "48": "favicon.svg",
        "128": "favicon.svg"
    }
}
